# ─────────────────────────────────────────────
# WebScope — Environment Variables
# 1. Bu dosyayı kopyala: cp .env.example .env.local
# 2. Aşağıdaki key'leri doldur
# 3. Vercel'e deploy ederken Settings > Environment Variables bölümüne ekle
# ─────────────────────────────────────────────

# ipinfo.io — Ücretsiz 50.000 sorgu/ay
# Kayıt: https://ipinfo.io/signup
IPINFO_TOKEN=your_ipinfo_token_here

# Google PageSpeed API — Ücretsiz 25.000 sorgu/gün
# Kayıt: https://console.cloud.google.com → PageSpeed Insights API
GOOGLE_PAGESPEED_KEY=your_google_api_key_here

# BuiltWith API — Ücretsiz 500 sorgu/ay
# Kayıt: https://api.builtwith.com
BUILTWITH_KEY=your_builtwith_key_here
